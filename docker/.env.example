# Host port overrides for docker-compose. Copy to `docker/.env` and edit ONLY if the default
# ports clash with something already running on your machine (compose auto-loads docker/.env).
#
# These remap the HOST side only. In-network service names/ports are unchanged, so the submitter,
# API, and worker pool keep working regardless of what you set here.

# Flink Web UI + REST API. NOTE: the docs' "Open in Flink UI" link points at localhost:8081, so if
# you change this, open the UI at the port you set (the convenience link won't match).
FLINK_UI_PORT=8081

# NestJS API + interactive docs. Safe to change — the docs use relative /api paths (same origin).
API_PORT=3000

# Kafka host listener (Ch 15/16). In-network harnesses always use kafka:29092 regardless.
KAFKA_PORT=9092

# Beam job server endpoints (only needed for the host submission lane / debugging).
JOB_PORT=8099
ARTIFACT_PORT=8098
EXPANSION_PORT=8097
